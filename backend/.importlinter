[importlinter]
root_packages = app

[importlinter:contract:clean-arch-layers]
name = Clean Architecture layer ordering
type = layers
layers =
    presentation
    infrastructure
    application
    domain
containers = app

[importlinter:contract:domain-no-config]
name = Domain must not depend on settings/config
type = forbidden
source_modules = app.domain
forbidden_modules = app.core.config
