# ── Environment ────────────────────────────────────────────────
ENVIRONMENT=development

# ── Application ────────────────────────────────────────────────
APP_NAME=bukoo
APP_DEBUG=true
APP_PORT=8000
APP_DESCRIPTION=My Project Description
APP_VERSION=0.1.0

# ── Security ───────────────────────────────────────────────────
SECRET_KEY=you-secret-key
CORS_ORIGINS=["*"]
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_PORT=5432
POSTGRES_DB=bukoo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Object Storage ───────────────────────────────
STORAGE_TYPE=minio
STREAM_CHUNK_SIZE=8mb

# ── MinIO (Object Storage — dev) ───────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bukoo
MINIO_USE_SSL=false

# ── AWS S3 (Production — leave blank in dev) ───────────────────
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Email / SMTP (Mailpit in dev) ──────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@bukoo.local
SMTP_TLS=false

# ── Google OAuth ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── Redis / Celery ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
