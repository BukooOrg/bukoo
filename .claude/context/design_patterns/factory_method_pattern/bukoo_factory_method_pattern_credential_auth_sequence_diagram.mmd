---
config:
  theme: white
  themeVariables:
    background: '#ffffff'
    primaryColor: '#ffffff'
    primaryTextColor: '#000000'
    lineColor: '#000000'
    secondaryColor: '#ffffff'
    tertiaryColor: '#ffffff'
    actorBorder: '#000000'
    actorTextColor: '#000000'
  look: classic
  mirrorActors: true
---
sequenceDiagram
    actor Client as Client
    participant Route as AuthRoute
    participant Factory as CredentialAuthProviderFactory
    participant UC as LoginUseCase
    participant Provider as CredentialAuthProvider
    participant DB as UserRepository
    Client->>Route: POST /auth/login (email, password)
    activate Route
    Route->>Factory: CredentialAuthProviderFactory(user_repo, hasher)
    Note right of Factory: Concrete factory instantiated<br>at the route layer
    Route->>UC: LoginUseCase(db_session, factory, token_svc)
    activate UC
    Route->>UC: await execute(payload)
    UC->>Factory: create_provider() [factory method]
    activate Factory
    Factory->>Provider: CredentialAuthProvider(user_repo, hasher)
    Note right of Provider: Concrete provider created.<br>UseCase receives IAuthProvider only.
    Factory-->>UC: IAuthProvider
    deactivate Factory
    UC->>Provider: await authenticate(payload)
    activate Provider
    Provider->>DB: fetch user by email
    activate DB
    DB-->>Provider: user record (hashed_password)
    deactivate DB
    Provider->>Provider: hash_and_compare(password, hashed_password)
    Provider-->>UC: AuthResult(user_id, email, provider="credential")
    deactivate Provider
    UC->>UC: await db_session.commit()
    UC-->>Route: AuthResult
    deactivate UC
    Route-->>Client: 200 OK
    deactivate Route