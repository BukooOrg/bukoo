meta {
  name: success
  type: http
  seq: 1
}

delete {
  url: {{baseUrl}}{{apiBase}}/notifications/{{notificationId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("status 204", function() {
    expect(res.status).to.equal(204);
  });

  test("response body is empty", function() {
    expect(res.body).to.be.empty;
  });
}
