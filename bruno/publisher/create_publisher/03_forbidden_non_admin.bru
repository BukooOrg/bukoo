meta {
  name: forbidden non admin
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}{{apiBase}}/publishers
  body: json
  auth: bearer
}

auth:bearer {
  // requires a USER-role token in {{userToken}}
  token: {{userToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  // USER role should be rejected with 403
  {
    "name": "Hachette Book Group"
  }
}

tests {
  test("status 403", function() {
    expect(res.status).to.equal(403);
  });

  test("error code is ADMIN_ACCESS_REQUIRED", function() {
    expect(res.body.error.code).to.equal("ADMIN_ACCESS_REQUIRED");
  });
}
