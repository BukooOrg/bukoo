meta {
  name: forbidden not admin
  type: http
  seq: 2
}

delete {
  url: {{baseUrl}}{{apiBase}}/publishers/{{publisherId}}
  body: none
  auth: bearer
}

auth:bearer {
  // requires a USER-role token in {{userToken}}
  token: {{userToken}}
}

tests {
  test("status 403", function() {
    expect(res.status).to.equal(403);
  });

  test("error code is ADMIN_ACCESS_REQUIRED", function() {
    expect(res.body.error.code).to.equal("ADMIN_ACCESS_REQUIRED");
  });
}
