meta {
  name: already active
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}{{apiBase}}/books/{{bookId}}/activate
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("status 409", function() {
    expect(res.status).to.equal(409);
  });
  
  test("success is false", function() {
    expect(res.body.success).to.be.false;
  });
  
  test("error code is BOOK_ALREADY_ACTIVE", function() {
    expect(res.body.error.code).to.equal("BOOK_ALREADY_ACTIVATED");
  });
}
