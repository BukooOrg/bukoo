meta {
  name: invalid status filter
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}{{apiBase}}/reports/jobs?status=unknown_status
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("status 422", function() {
    expect(res.status).to.equal(422);
  });

  test("success flag is false", function() {
    expect(res.body.success).to.be.false;
  });
}
