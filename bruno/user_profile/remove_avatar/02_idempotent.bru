meta {
  name: idempotent (avatar already null)
  type: http
  seq: 2
}

delete {
  url: {{baseUrl}}{{apiBase}}/users/me/avatar
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });

  test("success flag is true", function() {
    expect(res.body.success).to.be.true;
  });

  test("data.avatarUrl is null", function() {
    expect(res.body.data.avatarUrl).to.be.null;
  });
}
