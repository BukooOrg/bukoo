meta {
  name: no auth header
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}{{apiBase}}/users/me/avatar
  body: multipart-form
  auth: none
}

body:multipart-form {
  file: @file("avatar.jpg"); type=image/jpeg
}

tests {
  test("status 403", function() {
    expect(res.status).to.equal(403);
  });

  test("success flag is false", function() {
    expect(res.body.success).to.be.false;
  });
}
