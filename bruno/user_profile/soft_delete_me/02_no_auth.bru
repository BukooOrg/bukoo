meta {
  name: no auth header
  type: http
  seq: 2
}

delete {
  url: {{baseUrl}}{{apiBase}}/users/me
  body: none
  auth: none
}

tests {
  test("status 401", function() {
    expect(res.status).to.equal(401);
  });

  test("success flag is false", function() {
    expect(res.body.success).to.be.false;
  });

  test("meta has requestId", function() {
    expect(res.body.meta.requestId).to.be.a("string");
  });
}
