meta {
  name: filter by role
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}{{apiBase}}/users?role=admin
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });

  test("all items have role admin", function() {
    res.body.data.items.forEach(function(user) {
      expect(user.role).to.equal("admin");
    });
  });
}
