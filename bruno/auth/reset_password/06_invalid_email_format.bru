meta {
  name: invalid email format
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}{{apiBase}}/auth/password/reset
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  // email field is not a valid email address
  {
    "email": "not-an-email",
    "otp": "123456",
    "new_password": "NewP@ssw0rd1!"
  }
}

tests {
  test("status 422", function() {
    expect(res.status).to.equal(422);
  });
}
