meta {
  name: weak password
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}{{apiBase}}/auth/password/reset
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  // new_password fails strength rules — no uppercase, no special char
  {
    "email": "{{email1}}",
    "otp": "123456",
    "new_password": "weakpassword1"
  }
}

tests {
  test("status 422", function() {
    expect(res.status).to.equal(422);
  });
}
