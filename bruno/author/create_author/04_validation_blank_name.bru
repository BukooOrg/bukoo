meta {
  name: validation blank name
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}{{apiBase}}/authors
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{token}}
}

body:json {
  // name is empty string — should trigger 422
  {
    "name": ""
  }
}

tests {
  test("status 422", function() {
    expect(res.status).to.equal(422);
  });

  test("error code is VALIDATION_ERROR", function() {
    expect(res.body.error.code).to.equal("VALIDATION_ERROR");
  });
}
