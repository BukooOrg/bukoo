# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_PORT=5432
POSTGRES_DB=bukoo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
PGDATA=/var/lib/postgresql/data/pgdata

# ── MinIO (Object Storage — dev) ───────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bukoo
MINIO_USE_SSL=false
MINIO_PUBLIC=true

# ── AWS S3 (Production — leave blank in dev) ───────────────────
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── pgAdmin ────────────────────────────────────────────────────
PGADMIN_EMAIL=postgres@gmail.com
PGADMIN_PASSWORD=postgres
PGADMIN_CONFIG_SERVER_MODE=false
PGADMIN_CONFIG_MASTER_PASSWORD_REQUIRED=false


# ── Email / SMTP (Mailpit in dev) ──────────────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@bukoo.local
SMTP_TLS=false

# ── Redis ─────────────────────────────────────────────
BROKER_REDIS_URL=redis://localhost:6379/0
CACHE_REDIS_URL=redis://localhost:6379/1